{
  "name": "clinic-demo",
  "type": "task",
  "version": "1.0.0",
  "description": "在 ClinicalTrials.gov 搜索 Diabetes 相关临床试验，应用状态、性别和年龄筛选，选择录制轨迹中的前三个结果并触发下载。",
  "entry": "index.ts",
  "inferredIntent": "INFERRED_INTENT.md",
  "risk": "read_only",
  "requiresSession": false,
  "argsSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "condition": {
        "type": "string",
        "minLength": 1,
        "default": "Diabetes"
      },
      "conditionSearchTerm": {
        "type": "string",
        "minLength": 1,
        "default": "dia"
      },
      "selectedResultIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "default": ["hit-sel-0", "hit-sel-1", "hit-sel-2"]
      },
      "downloadDir": {
        "type": "string",
        "minLength": 1,
        "default": "downloads"
      }
    }
  }
}
