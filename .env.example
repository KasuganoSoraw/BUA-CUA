# Midscene reads model provider settings from environment variables.
# Qwen plus via Bailian OpenAI-compatible endpoint.
# Do not commit real API keys.
MIDSCENE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=qwen3.7-plus
MIDSCENE_MODEL_FAMILY=qwen

# Compatibility variables for @midscene/web 0.25.x.
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
MIDSCENE_USE_QWEN_VL=true

# Step recovery agent reads OpenAI-compatible Chat Completions settings.
# Do not commit real API keys.
BUA_CUA_RECOVERY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BUA_CUA_RECOVERY_API_KEY=
BUA_CUA_RECOVERY_MODEL=qwen3.7-plus
BUA_CUA_RECOVERY_VISION=true
BUA_CUA_RECOVERY_MAX_TURNS=6
BUA_CUA_MIDSCENE_FALLBACK_TIMEOUT_MS=120000

# Task Skill generation can produce a large JSON response, so keep a long timeout.
BUA_CUA_GENERATION_TIMEOUT=1800

# Optional MiniMax provider via Volcengine Ark OpenAI-compatible endpoint.
# Use CLI flags such as `--minimax` to switch generation/recovery/runtime model config.
BUA_CUA_MINIMAX_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
BUA_CUA_MINIMAX_API_KEY=
BUA_CUA_MINIMAX_MODEL=minimax-m3
# The toolkit sends `thinking: { "type": "disabled" }` automatically for --minimax.
