{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/bua-cua/skill.schema.json",
  "title": "BUA-CUA Task Skill",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "version", "entry", "argsSchema", "risk"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "type": { "const": "task" },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "entry": { "type": "string", "minLength": 1 },
    "inferredIntent": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path to an LLM-inferred task intent file, usually INFERRED_INTENT.md."
    },
    "risk": {
      "type": "string",
      "enum": ["read_only", "write_review_required", "destructive_review_required"]
    },
    "requiresSession": { "type": "boolean" },
    "preSkills": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "argsSchema": {
      "type": "object",
      "description": "JSON Schema object used to validate runtime args."
    }
  }
}
